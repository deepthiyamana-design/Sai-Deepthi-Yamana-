  <title>Zoom Sign In Clone</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Helvetica Neue', Arial, sans-serif;
    }

    body {
      background-color: #000;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .login-container {
      background-color: #fff;
      width: 100%;
      max-width: 400px;
      padding: 40px 30px;
      border-radius: 8px;
    }

    .logo {
      text-align: center;
      margin-bottom: 20px;
    }

    .logo h1 {
      color: #2D8CFF;
      font-size: 40px;
      font-weight: 600;
      letter-spacing: -1px;
    }

    .title {
      text-align: center;
      font-size: 24px;
      font-weight: 600;
      color: #232333;
      margin-bottom: 30px;
    }

    .input-group {
      position: relative;
      margin-bottom: 16px;
    }

    .input-group input {
      width: 100%;
      padding: 14px 14px 14px 45px;
      border: 1px solid #d1d1d6;
      border-radius: 8px;
      font-size: 16px;
      outline: none;
      transition: border 0.2s;
    }

    .input-group input:focus {
      border-color: #2D8CFF;
    }

    .input-group .icon {
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: #747487;
    }

    .input-group .forgot {
      position: absolute;
      right: 15px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      color: #747487;
      text-decoration: none;
      font-style: italic;
    }

    .forgot:hover {
      color: #2D8CFF;
    }

    .signin-btn {
      width: 100%;
      padding: 14px;
      background-color: #2D8CFF;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
      transition: background 0.2s;
    }

    .signin-btn:hover {
      background-color: #2681F2;
    }

    /* SVG icons */
    .icon-user, .icon-lock {
      width: 18px;
      height: 18px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
    }
  </style>
</head>
